# ------------------------------------------------------------------
# Orion — plantilla de variables de entorno
# Copia este fichero a `.env` y rellena los valores reales.
# NUNCA subas `.env` a git (ya está en .gitignore).
# ------------------------------------------------------------------

# Base de datos PostgreSQL (Supabase, Neon, o `npx prisma dev` en local)
DATABASE_URL="postgresql://usuario:password@localhost:5432/orion?schema=public"

# CJdropshipping — https://developers.cjdropshipping.com/
CJ_API_KEY=
CJ_API_SECRET=

# Stripe — https://dashboard.stripe.com/apikeys (usa claves de TEST al empezar)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend — emails transaccionales — https://resend.com/api-keys
RESEND_API_KEY=

# Secreto compartido para proteger el endpoint del cron de sincronización
CRON_SECRET=

# Secreto para firmar las sesiones del panel de admin (mínimo 32 caracteres).
# Genéralo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# URL pública del sitio (para links en emails, callbacks de Stripe, etc.)
# En local déjalo así; en Vercel (producción) vale "https://orion.boutique".
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Modo de la tienda: "preview" (próximamente + lista de espera) o "live" (venta real).
# Déjalo en preview hasta tener alta fiscal, Stripe live y CJ funcionando.
NEXT_PUBLIC_STORE_MODE="preview"
